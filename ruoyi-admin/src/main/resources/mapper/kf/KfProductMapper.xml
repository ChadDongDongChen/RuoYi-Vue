<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.web.kf.mapper.KfProductMapper">

    <resultMap type="KfProduct" id="KfProductResult">
        <result property="productId" column="product_id"/>
        <result property="productName" column="product_name"/>
        <result property="price" column="price"/>
        <result property="intro" column="intro"/>
        <result property="keywords" column="keywords"/>
        <result property="status" column="status"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectKfProductVo">
        select product_id, product_name, price, intro, keywords, status, sort_order,
               create_by, create_time, update_by, update_time, remark from kf_product
    </sql>

    <select id="selectKfProductList" parameterType="KfProduct" resultMap="KfProductResult">
        <include refid="selectKfProductVo"/>
        <where>
            <if test="productName != null and productName != ''">and product_name like concat('%', #{productName}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by sort_order asc, product_id asc
    </select>

    <select id="selectKfProductMatchKeywords" resultMap="KfProductResult">
        <include refid="selectKfProductVo"/>
        where status = '0'
        <if test="keyword != null and keyword != ''">
            and (
            product_name like concat('%', #{keyword}, '%')
            or intro like concat('%', #{keyword}, '%')
            or keywords like concat('%', #{keyword}, '%')
            )
        </if>
        order by sort_order asc, product_id asc
        limit 12
    </select>

    <select id="selectKfProductByProductId" resultMap="KfProductResult">
        <include refid="selectKfProductVo"/>
        where product_id = #{productId}
    </select>

    <insert id="insertKfProduct" useGeneratedKeys="true" keyProperty="productId">
        insert into kf_product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="price != null">price,</if>
            <if test="intro != null">intro,</if>
            <if test="keywords != null">keywords,</if>
            <if test="status != null">status,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="productName != null and productName != ''">#{productName},</if>
            <if test="price != null">#{price},</if>
            <if test="intro != null">#{intro},</if>
            <if test="keywords != null">#{keywords},</if>
            <if test="status != null">#{status},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateKfProduct">
        update kf_product
        <trim prefix="SET" suffixOverrides=",">
            <if test="productName != null and productName != ''">product_name = #{productName},</if>
            <if test="price != null">price = #{price},</if>
            <if test="intro != null">intro = #{intro},</if>
            <if test="keywords != null">keywords = #{keywords},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where product_id = #{productId}
    </update>

    <delete id="deleteKfProductByProductId">delete from kf_product where product_id = #{productId}</delete>

    <delete id="deleteKfProductByProductIds">
        delete from kf_product where product_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>
</mapper>
